<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Night theme: use the same light theme for consistent clean modern aesthetic -->
    <!-- Dark mode is disabled to maintain clean white & slate gray design -->
    <style name="AppThemeDayNight" parent="AppThemeBase">
        <!-- Force light mode for consistent clean modern aesthetic -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

</resources>