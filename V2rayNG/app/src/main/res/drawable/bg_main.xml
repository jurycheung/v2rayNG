<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#0A0E14"
                android:centerColor="#121820"
                android:endColor="#0A0E14"
                android:type="linear" />
        </shape>
    </item>
    <!-- Subtle grid overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0E14" />
        </shape>
    </item>
</layer-list>
